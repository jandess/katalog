{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/product/:slug",
      "destination": "/api/product/[slug].js"
    },
    {
      "source": "/product/:slug",
      "destination": "/api/product/[slug].js"
    },
    {
      "source": "/(cart|favs|profile|checkout|invoice|box-detail)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
